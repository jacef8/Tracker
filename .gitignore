# ── Dependencies ────────────────────────────────────────────────
node_modules/

# ── Capacitor / Android build artifacts (regenerable) ───────────
native-app/android/build/
native-app/android/app/build/
native-app/android/.gradle/
native-app/android/.idea/
native-app/android/captures/
native-app/android/local.properties
native-app/android/app/release/

# ── App / signing artifacts ─────────────────────────────────────
*.apk
# Whitelist the one APK we publish at /download (everything else stays ignored):
!public/GroundLink.apk
*.aab
*.keystore
*.jks
# Whitelist the committed signing keys so neither can ever be lost again:
# groundlink.keystore = debug-grade key (well-known password) used ONLY for local/sideload
# debug builds — Google Play rejects this one for uploads (it's flagged CN=Android Debug).
# groundlink-upload.keystore = the REAL Play Store upload key (release builds only), with a
# proper Distinguished Name — created after Play Console's upload-key-reset flow itself
# rejected the debug-flavored cert.
!native-app/android/app/groundlink.keystore
!native-app/android/app/groundlink-upload.keystore

# ── Logs / OS / editor cruft ────────────────────────────────────
*.log
npm-debug.log*
.DS_Store
Thumbs.db
.idea/
.vscode/
