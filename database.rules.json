{
  "rules": {
    "gl": {
      ".read": "auth != null",
      ".write": true
    },
    "gltest": {
      ".read": "auth != null",
      "$group": {
        "users": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "$other": { ".write": true }
      }
    },
    "$other": {
      ".read": true,
      ".write": true
    }
  }
}
