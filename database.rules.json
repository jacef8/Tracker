{
  "rules": {
    "gl": {
      ".read": true,
      ".write": true
    },
    "gltest": {
      "_devices": {
        "$deviceId": {
          ".read": true,
          ".write": true
        }
      },
      "_deviceShares": {
        "$code": {
          ".read": true,
          ".write": true
        }
      },
      "$group": {
        ".read": true,
        "users": {
          "$uid": {
            ".read": true,
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "$other": { ".write": true }
      }
    },
    "$other": {
      ".read": true,
      ".write": true
    }
  }
}
