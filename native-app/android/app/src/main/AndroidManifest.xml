<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App Links: open shared GroundLink https links (room invites, etc.) directly
                 in the app instead of the browser. android:autoVerify makes Android check
                 https://tracker-production-3b03.up.railway.app/.well-known/assetlinks.json
                 (served by server.js) against this app's signing cert on install; once
                 verified, taps on those links route here. MainActivity is singleTask, so the
                 URL arrives via @capacitor/app's appUrlOpen, which the web app routes to the
                 right room. Falls back to the browser/web for anyone without the app. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="tracker-production-3b03.up.railway.app" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- Background-geolocation foreground service. REQUIRED by
             @capacitor-community/background-geolocation: without this declaration the
             native service can deliver fixes only while the app is in the foreground, and
             Android suspends tracking the moment the app is backgrounded (the web
             geolocation watch then masks the failure until the OS kills it too). The
             foregroundServiceType="location" is mandatory on Android 14+. -->
        <service
            android:name="com.equimaps.capacitor_background_geolocation.BackgroundGeolocationService"
            android:foregroundServiceType="location"
            android:enabled="true"
            android:exported="true" />

        <!-- Keeps the LiveKit voice pipeline alive/receiving while backgrounded. See
             VoiceForegroundService.java for why the geolocation service above doesn't cover this
             (it only declares foregroundServiceType="location"). -->
        <service
            android:name=".VoiceForegroundService"
            android:foregroundServiceType="microphone|mediaPlayback"
            android:enabled="true"
            android:exported="false" />

        <!-- Survives what the background-geolocation plugin's own service can't: a device
             reboot before the app is reopened, and the app being swiped away from Recents. See
             HeadlessTrackerService.java for the full explanation (the vendored plugin
             deliberately stops itself the moment MainActivity/the Capacitor bridge dies). -->
        <service
            android:name=".HeadlessTrackerService"
            android:foregroundServiceType="location"
            android:enabled="true"
            android:exported="false" />

        <!-- Auto-starts HeadlessTrackerService right after boot, with no user action needed —
             see BootReceiver.java. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Location + background tracking -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Foreground service that keeps GPS alive when the app is backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Auto-start HeadlessTrackerService after a reboot, with no user action needed -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Foreground service that keeps voice reception alive when the app is backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Show the persistent "tracking" notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep the CPU awake for location while the screen is off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Vibrate for join / chat / pin / SOS alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Microphone for push-to-talk voice (WebView getUserMedia). Without this the
         WebView blocks the mic and it isn't even offered in app permissions. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
</manifest>
