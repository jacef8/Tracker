<?xml version="1.0" encoding="utf-8"?>
<!-- Status-bar notification icon: a location pin broadcasting signal waves — reads as
     "ground" (the pin) + "link" (the connection/broadcast arcs). Must stay a single-color
     silhouette on a transparent background; Android tints/masks notification icons to one
     color regardless of what's specified here, so intricate detail or multiple colors would
     be wasted (or render as a solid blob on some OEM skins). -->
