default_platform(:ios)

platform :ios do
  desc "Build and upload a build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"], # base64-encoded .p8 contents
      is_key_content_base64: true,
      in_house: false
    )

    # Keeps TestFlight build numbers monotonically increasing without hand-editing the
    # Xcode project every release — mirrors the Android side's APP_BUILD discipline.
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H")
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.groundlink.ios" => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
