<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>GroundLink</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- The app itself bundles no encryption of its own — all networking (Firebase, LiveKit
	     voice) runs through the WKWebView's system-provided WebKit/TLS stack, not code
	     shipped in the app binary. Declaring this here skips the manual "App Encryption
	     Documentation" prompt App Store Connect otherwise shows on every single build. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Location: GroundLink's core feature is live location sharing, including while
	     backgrounded (see VoiceForegroundService/foreground-service notes on the Android
	     side for the equivalent). -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>GroundLink shares your live location with your group so they can see where you are on the map.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>GroundLink keeps sharing your location with your group even when the app is in the background, so your position stays live on the map.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>GroundLink keeps sharing your location with your group even when the app is in the background, so your position stays live on the map.</string>

	<!-- Microphone: push-to-talk voice (WebRTC via WebView getUserMedia). -->
	<key>NSMicrophoneUsageDescription</key>
	<string>GroundLink uses the microphone for push-to-talk voice with your group.</string>

	<!-- Background modes: "location" keeps live tracking updating while backgrounded;
	     "audio" keeps the PTT voice channel receiving while backgrounded (the iOS
	     counterpart to Android's VoiceForegroundService — this is the mode that lets
	     incoming transmissions play even with the app not in the foreground); "fetch" and
	     "remote-notification" support push-triggered wake for messaging/notifications. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!-- Required for Google Sign-In (Firebase Authentication): the OAuth flow redirects back
	     into the app via this URL scheme, which must match REVERSED_CLIENT_ID in
	     GoogleService-Info.plist exactly. Without it, tapping "Sign in with Google" opens the
	     browser/Google auth sheet but the redirect back into the app silently fails. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.371034128407-23an0mp211k3kcl2goohjhob5a9s3mr6</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
